    <!-- Hero Section -->
    <header class="relative min-h-screen flex items-center justify-center text-center px-4">
        <div class="absolute inset-0 z-0">
            <img src="https://lh3.googleusercontent.com/d/1-EBrWOBw3lJK_Oa_PTzkVzkXPJhDsPOO" alt="Savad and Safreena" class="w-full h-full object-cover">
            <div class="absolute inset-0 hero-gradient"></div>
