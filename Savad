    </audio>

    <div id="musicToggle" class="hidden" onclick="toggleMusic()">
        <svg id="musicIcon" class="w-6 h-6 text-amber-700 spinning" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 3v10.55c-.59-.34-1.27-.55-2-.55-2.21 0-4 1.79-4 4s1.79 4 4 4 4-1.79 4-4V7h4V3h-6z"/>
