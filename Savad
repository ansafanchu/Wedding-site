            <button id="entryBtn" onclick="openInvitation()" class="px-12 py-4 bg-amber-700 text-white rounded-full font-semibold hover:bg-amber-800 transition-all shadow-xl tracking-widest uppercase text-xs">
                Open Invitation
            </button>
            <p id="loadingHint" class="hidden mt-4 text-xs text-amber-600 animate-pulse font-medium italic">Starting music...</p>
